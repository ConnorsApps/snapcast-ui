FROM debian:trixie-slim AS base
WORKDIR /app

RUN dpkg --add-architecture armhf && \
    apt-get update && apt-get upgrade -y && \
    apt-get install -y wget

FROM base AS server
WORKDIR /app

RUN apkArch="$(dpkg --print-architecture)"; \
    case "$apkArch" in \
    arm64) \
    wget https://github.com/badaix/snapcast/releases/download/v0.35.0/snapserver_0.35.0-1_armhf_trixie.deb -O ./snapserver.deb;; \
    amd64) \
    wget https://github.com/badaix/snapcast/releases/download/v0.35.0/snapserver_0.35.0-1_amd64_trixie.deb -O ./snapserver.deb;; \
    esac;

RUN apt-get install ./snapserver.deb -y

RUN rm -rf /var/lib/apt/lists/*

COPY docker/snapserver.conf /etc/snapserver.conf

ENTRYPOINT ["/usr/bin/snapserver", "--logging.sink=stdout"]


FROM base AS client
WORKDIR /app

RUN apkArch="$(dpkg --print-architecture)"; \
    case "$apkArch" in \
    arm64) \
    wget https://github.com/badaix/snapcast/releases/download/v0.35.0/snapclient_0.35.0-1_armhf_trixie.deb -O ./snapclient.deb;; \
    amd64) \
    wget https://github.com/badaix/snapcast/releases/download/v0.35.0/snapclient_0.35.0-1_amd64_trixie.deb -O ./snapclient.deb;; \
    esac;

RUN apt-get install ./snapclient.deb -y 

RUN rm -rf /var/lib/apt/lists/*

ENTRYPOINT ["/usr/bin/snapclient","--logsink=stdout","--host=snapcast-server","--player=file"]
